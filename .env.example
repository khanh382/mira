DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Cấu hình ứng dụng
APP_HOST=localhost
APP_PORT=8000

FRONTEND_URLS=http://localhost:3000

# Cấu hình JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Thiết lập múi giờ
TZ=Asia/Ho_Chi_Minh

# ─── Agent Workspace ───────────────────────────────────────────
# Thư mục gốc lưu trữ dữ liệu agent per-user (workspace, sessions, memory)
# Mỗi user sẽ có thư mục riêng: HEART_DIR/<user_identifier>/
# Tài nguyên dùng chung nằm ở: HEART_DIR/_shared/
HEART_DIR=./heart

# Model mặc định cho agent (có thể override per-user)
DEFAULT_MODEL=openai/gpt-4o