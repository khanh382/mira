DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Cấu hình ứng dụng
APP_HOST=localhost
APP_PORT=8000

FRONTEND_URLS=http://localhost:3000

# WebSocket /webchat (Socket.IO): Origin được phép (CSWSH). Cách nhau bằng dấu phẩy.
# Mặc định dùng FRONTEND_URLS nếu không set.
# WS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# Thời gian tối đa mỗi lần gọi code skill (ms) — AbortSignal; mặc định 20000.
# SKILL_EXEC_TIMEOUT_MS=20000

# Exec sandbox cứng (owner-only tool):
# - true (mặc định): chỉ cho phép command trong thư mục skills được phép
# - false: tắt sandbox (KHÔNG khuyến nghị)
# EXEC_STRICT_SANDBOX=true
# Allowlist binary cho exec (phân tách bằng dấu phẩy). Mặc định: git
# Dùng "*" để cho phép mọi binary (vẫn áp dụng các guard exec khác nếu đang bật).
# EXEC_ALLOWED_BINARIES=git
# Bật toàn bộ guard bảo mật cho exec (sandbox + policy + audit/rate limit bên dưới).
# EXEC_GUARD_ENABLED=true
# Audit log cho mọi lần gọi exec (allow/deny).
# EXEC_AUDIT_LOG_ENABLED=true
# Rate limit owner actions trên exec.
# EXEC_OWNER_RATE_LIMIT_ENABLED=true
# EXEC_OWNER_RATE_LIMIT_MAX=20
# EXEC_OWNER_RATE_LIMIT_WINDOW_MS=60000

# SSRF: chặn localhost/private IP chỉ khi NODE_ENV=production. Dev: không chặn.
# Tắt chặn trên staging giống dev: WEB_FETCH_SSRF_STRICT=false
# WEB_FETCH_SSRF_STRICT=true

# Chỉ owner (và chỉ khi SSRF đang bật): cho phép web_fetch tới URL nội bộ — debug server.
# WEB_FETCH_ALLOW_PRIVATE_URLS=false

# ─── SMTP (gửi email xác minh đăng nhập, reset password) ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
# Địa chỉ hiển thị ở trường From (nếu khác SMTP_USER)
# SMTP_FROM="Mira System <noreply@example.com>"

# Cấu hình JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h
# BIP39 seed phrase (12/24 words) để derive identifier BTC cho user mới
SEED_PHRASE="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"
# Refresh secret tự động derive: sha256("refresh:" + JWT_SECRET) — không cần cấu hình thêm.
# Cookie Secure flag: production thường bật (HTTPS). Ghi đè: COOKIE_SECURE=true|false
# COOKIE_SECURE=true

# Thiết lập múi giờ
TZ=Asia/Ho_Chi_Minh

# ─── Redis (optional) ──────────────────────────────────────────
# (Giữ lại nếu bạn dùng Redis cho hệ thống khác.)
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
#
# Poll interval (ms) khi backend chờ callback n8n update DB dispatch state.
# WORKFLOW_TASK_POLL_MS=2000

# Giới hạn số pipeline chạy song song trên mỗi user (mặc định: owner=3, colleague=2, client=1).
# MAX_CONCURRENT_RUNS_OWNER=3
# MAX_CONCURRENT_RUNS_COLLEAGUE=2
# MAX_CONCURRENT_RUNS_CLIENT=1

# ─── Agent Workspace ───────────────────────────────────────────
# Thư mục gốc lưu trữ dữ liệu agent per-user (workspace, sessions, memory)
# Mỗi user sẽ có thư mục riêng: BRAIN_DIR/<user_identifier>/
# Tài nguyên dùng chung nằm ở: BRAIN_DIR/_shared/
BRAIN_DIR=./brains

# ClawhHub prompt skills: `npx clawhub install` ghi vào thư mục này.
# Mặc định: $BRAIN_DIR/clawhub_skills (BRAIN_DIR không set → xem DEFAULT_BRAIN_DIR trong src/config/brain-dir.config.ts). Ghi đè nếu cần:
# CLAWHUB_MANAGED_SKILLS_DIR=/absolute/path/to/skills

# Model mặc định cho agent (fallback cuối khi Smart Router không tìm được model nào)
# Smart Router tự động chọn model theo intent + skill tier + user level
# Chỉ dùng DEFAULT_MODEL khi không có API key nào trong bảng config
DEFAULT_MODEL=openai/gpt-4o

# Số tin nhắn gần nhất (user + assistant) load từ DB vào context LLM mỗi lượt (mặc định 30, tối đa 120).
# CHAT_HISTORY_LIMIT=40

# Model cho job LLM nền (tóm tắt session, compact MEMORY, daily consolidate, extract preference).
# Thứ tự chọn: CONTEXT_FOCUS_MODEL → DEFAULT_MODEL → model tier CHEAP đầu tiên resolve được (vd. deepseek/deepseek-v3.2, openai/gpt-4o-mini).
# Chỉ có OpenRouter: dùng tiền tố provider, vd. openrouter/openai/gpt-4o-mini.
# CONTEXT_FOCUS_MODEL=openrouter/openai/gpt-4o-mini

# ─── Context Budget ──────────────────────────────────────────
# Giới hạn ký tự MEMORY.md inject vào system prompt (mặc định 6000; giữ phần mới nhất).
# SYSTEM_CONTEXT_MAX_MEMORY_CHARS=6000
# Giới hạn ký tự USER_CONTEXT.md inject vào system prompt (mặc định 2000).
# SYSTEM_CONTEXT_MAX_USER_CONTEXT_CHARS=2000
# Giới hạn ký tự daily notes inject vào system prompt (mặc định 3000).
# SYSTEM_CONTEXT_MAX_DAILY_CHARS=3000
# Giới hạn tổng ký tự conversation history (user+assistant) — bổ sung CHAT_HISTORY_LIMIT (đếm message).
# CHAT_HISTORY_MAX_CHARS=32000

# Hard cap cho *system message* sau khi inject persona/prefs/semantic/tool stats…
# (mặc định 18000). Nếu vượt, hệ thống sẽ trim các block ưu tiên thấp trước.
# SYSTEM_PROMPT_MAX_CHARS=18000

# ─── Interaction Memory (automatic long-term learning) ────────
# Tự động trích "facts/projects/decisions" từ chat và append vào MEMORY.md.
# Scope: owner (default) hoặc all
# INTERACTION_MEMORY_SCOPE=owner
# Chạy mỗi N lượt assistant per thread (mặc định 8)
# INTERACTION_MEMORY_INTERVAL_TURNS=8
# Tắt hoàn toàn (true/false)
# INTERACTION_MEMORY_DISABLED=false

# ─── Memory Lifecycle ────────────────────────────────────────
# MEMORY.md compact khi vượt ngưỡng ký tự (mặc định 12000). Giữ N ký tự mới nhất nguyên.
# MEMORY_COMPACTION_THRESHOLD_CHARS=12000
# MEMORY_COMPACTION_KEEP_TAIL_CHARS=3000
# Daily note consolidate vào MEMORY.md khi vượt ngưỡng (mặc định 4000).
# DAILY_NOTE_CONSOLIDATION_THRESHOLD_CHARS=4000
# Sau khi consolidate, đánh dấu daily note (true) hay để nguyên (false). Mặc định true.
# DAILY_NOTE_ARCHIVE=true
# Tắt auto-inject semantic memory search vào preprocess (mặc định bật).
# SEMANTIC_INJECT_DISABLED=false
# Chỉ tìm vector trong cùng thread với phiên hiện tại khi inject semantic (mặc định bật). Đặt false để gợi ý từ mọi thread của user.
# SEMANTIC_SEARCH_THREAD_SCOPED=true

# ─── User Preference Learning ────────────────────────────────
# Bật synchronize DB cho dev (tự tạo bảng mới). Production: false.
# DB_SYNCHRONIZE=false
# Số lượt assistant reply giữa 2 lần extract preferences (mặc định 5).
# PREFERENCE_EXTRACT_INTERVAL=5

# ─── Google Workspace (gogcli) ────────────────────────────────
# Đường dẫn tới binary gog (mặc định: tìm trong PATH)
# GOG_BIN=gog
# Thư mục config gogcli (mặc định: ~/.config/gogcli)
# GOG_CONFIG_DIR=~/.config/gogcli
# Password cho encrypted keyring (bắt buộc trên server/CI)
GOG_KEYRING_PASSWORD=your_keyring_password

# ─── Bot Webhook Auto-Registration ───────────────────────────
# URL công khai của server. BotBootstrapService sẽ tự động đăng ký
# webhook cho Telegram khi khởi động & mỗi khi phát hiện token mới.
# Discord/Zalo: log URL để bạn set thủ công trong Developer Portal.
# Nếu chưa set → bỏ qua auto-registration (webhook phải set thủ công).
# WEBHOOK_BASE_URL=https://your-public-domain.com

# Discord Application ID (dùng cho interaction followup)
# DISCORD_APPLICATION_ID=your_discord_app_id

# ─── Web search (tool web_search / /web_search) ─────────────────
# Thứ tự ưu tiên: BRAVE_API_KEY → PERPLEXITY_API_KEY → Google Custom Search (cả hai biến dưới).
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=
# Google Custom Search JSON API: API key (Google Cloud) + Search Engine ID (cx) từ Programmable Search Engine
# https://developers.google.com/custom-search/v1/overview
# Trong console engine: bật tìm trên web; với web_search searchType=image cần engine hỗ trợ Image search.
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=

# ─── n8n (hidden instance) ─────────────────────────────────────
# Webhook URL để Mira dispatch workflow (n8n side: một webhook entrypoint).
# Ví dụ (Docker network): http://n8n:5678/webhook/mira-dispatch
# N8N_DISPATCH_URL=
#
# Secret để ký request Mira→n8n (HMAC-SHA256 trên canonical JSON).
# n8n phải verify headers: x-mira-ts, x-mira-nonce, x-mira-signature
# N8N_DISPATCH_SECRET=
#
# URL callback mà n8n sẽ gọi về Mira (n8n→Mira). Phải là URL mà n8n truy cập được.
# Ví dụ (cùng cluster/private): http://mira-backend:8000/api/v1/webhooks/n8n/callback
# N8N_CALLBACK_URL=
#
# Secret để ký callback n8n→Mira (HMAC-SHA256 trên canonical JSON).
# N8N_CALLBACK_SECRET=
#
# TTL cho timestamp signature (ms). Default: 300000 (5 phút).
# N8N_CALLBACK_TTL_MS=300000
#
# Timeout cho dispatch HTTP request (ms). Default: 12000.
# N8N_DISPATCH_TIMEOUT_MS=12000
#
# Allowlist workflowKey theo level (comma-separated). Không set = mặc định tắt.
# N8N_WORKFLOWS_COMMON=
# N8N_WORKFLOWS_OWNER=
# N8N_WORKFLOWS_COLLEAGUE=
# N8N_WORKFLOWS_CLIENT=

# Header name for n8n → Mira brain endpoint API key.
# Default: x-mira-api-key
# N8N_BRAIN_API_KEY_HEADER=x-mira-api-key
