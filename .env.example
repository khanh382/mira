DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Cấu hình ứng dụng
APP_HOST=localhost
APP_PORT=8000

FRONTEND_URLS=http://localhost:3000

# Cấu hình JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Thiết lập múi giờ
TZ=Asia/Ho_Chi_Minh

# ─── Agent Workspace ───────────────────────────────────────────
# Thư mục gốc lưu trữ dữ liệu agent per-user (workspace, sessions, memory)
# Mỗi user sẽ có thư mục riêng: BRAIN_DIR/<user_identifier>/
# Tài nguyên dùng chung nằm ở: BRAIN_DIR/_shared/
BRAIN_DIR=./heart

# ClawhHub prompt skills: `npx clawhub install` ghi vào thư mục này.
# Mặc định: $BRAIN_DIR/clawhub_skills (BRAIN_DIR không set → xem DEFAULT_BRAIN_DIR trong src/config/brain-dir.config.ts). Ghi đè nếu cần:
# CLAWHUB_MANAGED_SKILLS_DIR=/absolute/path/to/skills

# Model mặc định cho agent (fallback cuối khi Smart Router không tìm được model nào)
# Smart Router tự động chọn model theo intent + skill tier + user level
# Chỉ dùng DEFAULT_MODEL khi không có API key nào trong bảng config
DEFAULT_MODEL=openai/gpt-4o

# ─── Google Workspace (gogcli) ────────────────────────────────
# Đường dẫn tới binary gog (mặc định: tìm trong PATH)
# GOG_BIN=gog
# Thư mục config gogcli (mặc định: ~/.config/gogcli)
# GOG_CONFIG_DIR=~/.config/gogcli
# Password cho encrypted keyring (bắt buộc trên server/CI)
GOG_KEYRING_PASSWORD=your_keyring_password

# ─── Bot Webhook Auto-Registration ───────────────────────────
# URL công khai của server. BotBootstrapService sẽ tự động đăng ký
# webhook cho Telegram khi khởi động & mỗi khi phát hiện token mới.
# Discord/Zalo: log URL để bạn set thủ công trong Developer Portal.
# Nếu chưa set → bỏ qua auto-registration (webhook phải set thủ công).
# WEBHOOK_BASE_URL=https://your-public-domain.com

# Discord Application ID (dùng cho interaction followup)
# DISCORD_APPLICATION_ID=your_discord_app_id