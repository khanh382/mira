DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Cấu hình ứng dụng
APP_HOST=localhost
APP_PORT=8000

FRONTEND_URLS=http://localhost:3000

# WebSocket /webchat (Socket.IO): Origin được phép (CSWSH). Cách nhau bằng dấu phẩy.
# Mặc định dùng FRONTEND_URLS nếu không set.
# WS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# Thời gian tối đa mỗi lần gọi code skill (ms) — AbortSignal; mặc định 20000.
# SKILL_EXEC_TIMEOUT_MS=20000

# SSRF: chặn localhost/private IP chỉ khi NODE_ENV=production. Dev: không chặn.
# Tắt chặn trên staging giống dev: WEB_FETCH_SSRF_STRICT=false
# WEB_FETCH_SSRF_STRICT=true

# Chỉ owner (và chỉ khi SSRF đang bật): cho phép web_fetch tới URL nội bộ — debug server.
# WEB_FETCH_ALLOW_PRIVATE_URLS=false

# Cấu hình JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRES_IN=24h

# Thiết lập múi giờ
TZ=Asia/Ho_Chi_Minh

# ─── Redis / workflow (tiến trình OpenClaw, BullMQ) ─────────────
# Khi Redis chạy: hàng đợi job workflow dùng BullMQ. Khi không kết nối được → fallback RAM (một process).
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# Chu kỳ ping lại Redis để tự chuyển từ RAM sang BullMQ (ms). 0 = không thử lại.
# WORKFLOW_REDIS_RETRY_MS=30000
# true = luôn dùng RAM, không dùng Redis (dev không cài Redis).
# WORKFLOW_FORCE_MEMORY=false

# ─── Agent Workspace ───────────────────────────────────────────
# Thư mục gốc lưu trữ dữ liệu agent per-user (workspace, sessions, memory)
# Mỗi user sẽ có thư mục riêng: BRAIN_DIR/<user_identifier>/
# Tài nguyên dùng chung nằm ở: BRAIN_DIR/_shared/
BRAIN_DIR=./brains

# ClawhHub prompt skills: `npx clawhub install` ghi vào thư mục này.
# Mặc định: $BRAIN_DIR/clawhub_skills (BRAIN_DIR không set → xem DEFAULT_BRAIN_DIR trong src/config/brain-dir.config.ts). Ghi đè nếu cần:
# CLAWHUB_MANAGED_SKILLS_DIR=/absolute/path/to/skills

# Model mặc định cho agent (fallback cuối khi Smart Router không tìm được model nào)
# Smart Router tự động chọn model theo intent + skill tier + user level
# Chỉ dùng DEFAULT_MODEL khi không có API key nào trong bảng config
DEFAULT_MODEL=openai/gpt-4o

# Số tin nhắn gần nhất (user + assistant) load từ DB vào context LLM mỗi lượt (mặc định 30, tối đa 120).
# CHAT_HISTORY_LIMIT=40

# Model cho job LLM nền (tóm tắt session, compact MEMORY, daily consolidate, extract preference).
# Thứ tự chọn: CONTEXT_FOCUS_MODEL → DEFAULT_MODEL → model tier CHEAP đầu tiên resolve được (vd. deepseek/deepseek-chat, openai/gpt-4o-mini).
# Chỉ có OpenRouter: dùng tiền tố provider, vd. openrouter/openai/gpt-4o-mini.
# CONTEXT_FOCUS_MODEL=openrouter/openai/gpt-4o-mini

# ─── Context Budget ──────────────────────────────────────────
# Giới hạn ký tự MEMORY.md inject vào system prompt (mặc định 6000; giữ phần mới nhất).
# SYSTEM_CONTEXT_MAX_MEMORY_CHARS=6000
# Giới hạn ký tự daily notes inject vào system prompt (mặc định 3000).
# SYSTEM_CONTEXT_MAX_DAILY_CHARS=3000
# Giới hạn tổng ký tự conversation history (user+assistant) — bổ sung CHAT_HISTORY_LIMIT (đếm message).
# CHAT_HISTORY_MAX_CHARS=32000

# ─── Memory Lifecycle ────────────────────────────────────────
# MEMORY.md compact khi vượt ngưỡng ký tự (mặc định 12000). Giữ N ký tự mới nhất nguyên.
# MEMORY_COMPACTION_THRESHOLD_CHARS=12000
# MEMORY_COMPACTION_KEEP_TAIL_CHARS=3000
# Daily note consolidate vào MEMORY.md khi vượt ngưỡng (mặc định 4000).
# DAILY_NOTE_CONSOLIDATION_THRESHOLD_CHARS=4000
# Sau khi consolidate, đánh dấu daily note (true) hay để nguyên (false). Mặc định true.
# DAILY_NOTE_ARCHIVE=true
# Tắt auto-inject semantic memory search vào preprocess (mặc định bật).
# SEMANTIC_INJECT_DISABLED=false

# ─── User Preference Learning ────────────────────────────────
# Bật synchronize DB cho dev (tự tạo bảng mới). Production: false.
# DB_SYNCHRONIZE=false
# Số lượt assistant reply giữa 2 lần extract preferences (mặc định 5).
# PREFERENCE_EXTRACT_INTERVAL=5

# ─── Google Workspace (gogcli) ────────────────────────────────
# Đường dẫn tới binary gog (mặc định: tìm trong PATH)
# GOG_BIN=gog
# Thư mục config gogcli (mặc định: ~/.config/gogcli)
# GOG_CONFIG_DIR=~/.config/gogcli
# Password cho encrypted keyring (bắt buộc trên server/CI)
GOG_KEYRING_PASSWORD=your_keyring_password

# ─── Bot Webhook Auto-Registration ───────────────────────────
# URL công khai của server. BotBootstrapService sẽ tự động đăng ký
# webhook cho Telegram khi khởi động & mỗi khi phát hiện token mới.
# Discord/Zalo: log URL để bạn set thủ công trong Developer Portal.
# Nếu chưa set → bỏ qua auto-registration (webhook phải set thủ công).
# WEBHOOK_BASE_URL=https://your-public-domain.com

# Discord Application ID (dùng cho interaction followup)
# DISCORD_APPLICATION_ID=your_discord_app_id

# ─── Web search (tool web_search / /web_search) ─────────────────
# Thứ tự ưu tiên: BRAVE_API_KEY → PERPLEXITY_API_KEY → Google Custom Search (cả hai biến dưới).
# BRAVE_API_KEY=
# PERPLEXITY_API_KEY=
# Google Custom Search JSON API: API key (Google Cloud) + Search Engine ID (cx) từ Programmable Search Engine
# https://developers.google.com/custom-search/v1/overview
# Trong console engine: bật tìm trên web; với web_search searchType=image cần engine hỗ trợ Image search.
# GOOGLE_CUSTOM_SEARCH_API_KEY=
# GOOGLE_CUSTOM_SEARCH_ENGINE_ID=
